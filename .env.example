# Database Configuration
DATABASE_URL=mysql://user:password@localhost:3306/english_learning_hub

# JWT Secret for session signing
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OAuth Configuration
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://manus.im/login

# Application Origin
APP_ORIGIN=http://localhost:3000

# Ollama Configuration (for AI course generation and writing feedback)
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Optional: Analytics and Monitoring
VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# Optional: Built-in Forge API (for advanced features)
BUILT_IN_FORGE_API_URL=https://api.manus.im/forge
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://api.manus.im/forge
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key
